rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========= Helpers =========
    function isSignedIn() {
      return request.auth != null;
    }

    function supplierId() {
      return isSignedIn()
        && request.auth.token != null
        && request.auth.token.supplierId != null
        ? request.auth.token.supplierId
        : null;
    }
    function isSupplierUser() {
      return supplierId() != null;
    }

    function isVenueMember(venueId) {
      return isSignedIn() && (
        (request.auth.token.keys().hasAny(['venues']) && request.auth.token.venues[venueId] == true) ||
        exists(/databases/$(database)/documents/venues/$(venueId)/members/$(request.auth.uid))
      );
    }

    function hasVenueRole(venueId, allowed) {
      return isVenueMember(venueId) && (
        (request.auth.token.keys().hasAny(['venue_roles']) && allowed.hasAny([request.auth.token.venue_roles[venueId]])) ||
        allowed.hasAny([
          get(/databases/$(database)/documents/venues/$(venueId)/members/$(request.auth.uid)).data.role
        ])
      );
    }

    function hasOnlyFields(data, allowedKeys) {
      return data.keys().hasOnly(allowedKeys);
    }

    function supplierMatchesOrderData(orderData) {
      return isSupplierUser()
        && orderData != null
        && orderData.keys().hasAny(['supplierId'])
        && orderData.supplierId == supplierId();
    }

    function supplierAllowedOrderUpdate() {
      return supplierMatchesOrderData(resource.data)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'supplierStatus',
          'supplierStatusUpdatedAt',
          'acceptedAt',
          'shippedAt',
          'deliveredAt',
          'invoice'
        ])
        && request.resource.data.supplierId == resource.data.supplierId
        && (
          !request.resource.data.keys().hasAny(['invoice']) ||
          request.resource.data.invoice == null ||
          request.resource.data.invoice.keys().hasOnly(['storagePath','source','invoiceNumber'])
        );
    }

    function isThisSupplier(sid) {
      return isSignedIn() && supplierId() == sid;
    }

    function isConnectedVenueMember(sid) {
      // Checks if the user's UID is listed in the supplier's connectedVenueMembers array.
      // connectedVenueMembers stores individual UIDs (not venueIds) for efficient rule evaluation.
      // This field is written when a venue connection is established.
      return isSignedIn()
        && exists(/databases/$(database)/documents/supplierAccounts/$(sid))
        && get(/databases/$(database)/documents/supplierAccounts/$(sid))
             .data.get('connectedVenueMembers', []).hasAny([request.auth.uid]);
    }

    // ========= Root collections =========
    match /global_products/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && !('accountNumber' in request.resource.data)
        && !('pricing' in request.resource.data);
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).changedKeys()
             .hasOnly(['name','brand','size','category','abv','countryOfOrigin',
                       'updatedAt','addedByVenue','unit',
                       'barcode','barcodeNumber','barcodes']);
      allow delete: if false;
    }

    match /global_recipes/{id} {
      allow read: if isSignedIn();
      // Written by the generate-recipe Cloud Function via the Admin SDK, which
      // bypasses these rules — no client-side writes are permitted.
      allow write: if false;
    }

    match /global_suppliers/{id} {
      allow read: if isSignedIn();
      // Any signed-in user may contribute public supplier data.
      // Private fields (accountNumber, pricing, privateNotes) are blocked.
      allow create, update: if isSignedIn()
        && !('accountNumber' in request.resource.data)
        && !('pricing' in request.resource.data)
        && !('privateNotes' in request.resource.data);
      allow delete: if false;
      match /items/{itemId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn();
        allow delete: if false;
      }
    }

    // ========= Supplier Accounts =========
    // Commercial supplier data — pricing, orders, specials, contracts.
    // Only the supplier themselves and members of explicitly connected venues can access.
    // connectedVenueMembers[] stores individual UIDs for efficient rule evaluation.
    match /supplierAccounts/{sid} {

      // Root account doc: supplier reads own account only.
      // Connected venue members cannot read the root doc (contains connectedVenues, config).
      allow read: if isThisSupplier(sid);
      allow write: if isThisSupplier(sid);

      // Catalogue: supplier manages, connected venue members can read for pricing.
      match /catalogue/{productId} {
        allow read: if isThisSupplier(sid) || isConnectedVenueMember(sid);
        allow write: if isThisSupplier(sid);
        allow delete: if isThisSupplier(sid);
      }

      // Specials: supplier manages, connected venue members can read active promotions.
      match /specials/{specialId} {
        allow read: if isThisSupplier(sid) || isConnectedVenueMember(sid);
        allow write: if isThisSupplier(sid);
        allow delete: if isThisSupplier(sid);
      }

      // Orders: supplier manages, venue members can create and read their own orders.
      match /orders/{orderId} {
        // Supplier sees all orders.
        // Venue member can read if the order's venueId is a venue they belong to.
        allow read: if isThisSupplier(sid)
          || (isConnectedVenueMember(sid)
              && isVenueMember(resource.data.venueId));
        // Venue member can create an order for a venue they belong to.
        allow create: if isConnectedVenueMember(sid)
          && isVenueMember(request.resource.data.venueId)
          && request.resource.data.keys().hasAll(['venueId', 'lines', 'status'])
          && request.resource.data.status == 'pending';
        // Only supplier can update order status (acknowledge, fulfill, etc).
        allow update: if isThisSupplier(sid);
        allow delete: if isThisSupplier(sid);
      }

      // Contracts: supplier and the specific venue named in the contract.
      match /contracts/{contractId} {
        allow read: if isThisSupplier(sid)
          || (isConnectedVenueMember(sid)
              && isVenueMember(resource.data.venueId));
        allow write: if isThisSupplier(sid);
        allow delete: if isThisSupplier(sid);
      }

      // Connections: supplier manages connection requests.
      // Venue members can read their own connection status.
      match /connections/{venueId} {
        allow read: if isThisSupplier(sid) || isVenueMember(venueId);
        allow write: if isThisSupplier(sid);
        // Venue can create a connection request (pending status only).
        allow create: if isVenueMember(venueId)
          && request.resource.data.status == 'pending';
      }
    }

    match /supplierRegistrations/{regId} {
      // Anyone can submit a registration — no login required to apply
      allow create: if true;
      // Only Hosti admin can read, update, or delete registrations
      allow read, update, delete: if request.auth != null
        && request.auth.token.email == 'poni@hosti.co.nz';
    }

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'venueId','createdAt','email','touchedAt','displayName',
          'activeVenueId','venueIds'
        ]);
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'venueId','touchedAt','displayName',
          'activeVenueId','venueIds',
          'fcmTokens','fcmTokenUpdatedAt'
        ]);
      allow delete: if false;
    }

    match /deletionLog/{logId} {
      // Admin SDK only — no client access
      allow read, write: if false;
    }

    // ========= Venue-scoped =========
    match /venues/{venueId} {

      allow read: if isVenueMember(venueId);
      // TODO (post-pilot): move stripeCustomerId + stripeSubscriptionId out of the venue
      // document into venues/{venueId}/billing/config restricted to owner only.
      // Firestore rules cannot restrict individual fields on a document read —
      // the whole document must be moved to a subcollection to limit access.

      // Allow a signed-in user to create a new venue where they are the declared owner.
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.keys().hasAll(['name', 'ownerUid', 'venueType', 'createdAt', 'updatedAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.venueType in ['venue', 'festival'];

      allow delete: if hasVenueRole(venueId, ['owner']);

      allow update: if hasVenueRole(venueId, ['manager','owner'])
        && hasOnlyFields(request.resource.data, ['cycleResetAt','updatedAt'])
        && (request.resource.data.cycleResetAt is timestamp)
        && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
      allow update: if isVenueMember(venueId)
        && hasOnlyFields(request.resource.data, ['cycleResetAt','updatedAt'])
        && (request.resource.data.cycleResetAt is timestamp)
        && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);

      // Venue name (owner only)
      allow update: if hasVenueRole(venueId, ['owner'])
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['name'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 100;

      // Venue-level preferences (managers/owners only)
      allow update: if hasVenueRole(venueId, ['manager','owner'])
        && request.resource.data.diff(resource.data).changedKeys()
             .hasOnly(['weeklySummaryEmail', 'timezone', 'autoSuggestPar']);

      // Onboarding state (managers/owners complete roads; any member can dismiss)
      allow update: if hasVenueRole(venueId, ['manager','owner'])
        && request.resource.data.diff(resource.data).changedKeys()
             .hasOnly(['onboardingRoad', 'onboardingCompletedAt',
                       'onboardingLastStocktakeDate', 'onboardingHasInvoices']);
      allow update: if isVenueMember(venueId)
        && request.resource.data.diff(resource.data).changedKeys()
             .hasOnly(['onboardingDismissedAt']);

      // Stocktake completion counter (incremented by any member on submit)
      allow update: if isVenueMember(venueId)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['totalStocktakesCompleted']);

      match /members/{uid} {
        allow read: if isVenueMember(venueId);
        allow create, update, delete: if hasVenueRole(venueId, ['owner','manager']);
        // Bootstrap: owner can create their own first member doc before membership exists.
        allow create: if request.auth != null
          && uid == request.auth.uid
          && request.resource.data.role == 'owner'
          && get(/databases/$(database)/documents/venues/$(venueId)).data.ownerUid == request.auth.uid;
      }

      match /integrations/{integrationId} {
        // Connection-status docs for OAuth-style external integrations (Xero,
        // MYOB). No path existed here before — Xero's client reads/writes to
        // this same path but had nothing granting access; this rule covers
        // both. Tokens are never stored here — see venues/{venueId}/integrationTokens,
        // which has no client rule at all and is only ever written server-side
        // via the Admin SDK (which bypasses these rules entirely).
        allow read, create, update, delete: if isVenueMember(venueId)
          && integrationId in ['xero', 'myob'];
      }

      match /posIntegration/{docId} {
        // POS integration config — adapter selection, connection status.
        // No tokens stored here (those live in integrationTokens, Admin SDK only).
        // Any venue member can read; only managers/owners can write.
        allow read: if isVenueMember(venueId);
        allow write: if hasVenueRole(venueId, ['manager', 'owner']);
      }

      match /posProductMappings/{mappingId} {
        // POS product mappings — links between venue products/recipes and POS items.
        // Any venue member can read; managers/owners can write.
        allow read: if isVenueMember(venueId);
        allow write: if hasVenueRole(venueId, ['manager', 'owner']);
      }

      match /settings/{settingId} {
        // Venue operational settings (hourly rate, stocktake baseline, days of cover, etc.)
        // Any venue member can read; managers and owners can write.
        allow read: if isVenueMember(venueId);
        allow write: if hasVenueRole(venueId, ['manager', 'owner']);
      }

      match /profitRecoverySnapshots/{snapshotId} {
        // Monthly Hosti Health snapshots — written by client on score calculation.
        allow read: if isVenueMember(venueId);
        allow write: if hasVenueRole(venueId, ['manager', 'owner']);
      }

      match /invites/{inviteId} {
        // Any venue member can read invites (to check status)
        allow read: if isVenueMember(venueId);
        // Only owners and managers can create invites
        allow create: if hasVenueRole(venueId, ['owner','manager'])
          && request.resource.data.keys().hasAll(['email','role','status','createdAt'])
          && request.resource.data.status == 'pending'
          && request.resource.data.role in ['owner','manager','staff']
          && request.resource.data.createdAt is timestamp;
        // Only owners and managers can cancel (delete) invites
        allow delete: if hasVenueRole(venueId, ['owner','manager']);
        // Status updates (accept/expire) are done server-side via Cloud Function only
        allow update: if false;
      }

      match /departments/{departmentId} {
        allow read: if isVenueMember(venueId);
        allow create, update: if hasVenueRole(venueId, ['manager','owner']);
        allow delete: if hasVenueRole(venueId, ['owner']);

        // Any member can update cycle tracking fields (set by staff when completing areas)
        allow update: if isVenueMember(venueId)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['totalCyclesCompleted', 'lastCycleAt', 'lastCycleCompletedBy',
                         'lastStockTakeAt', 'lastStockTakeWindowHours']);

        match /areas/{areaId} {
          allow read: if isVenueMember(venueId);

          allow update: if isVenueMember(venueId)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['currentLock'])
            && (
              request.resource.data.currentLock is map ||
              request.resource.data.currentLock == null
            );

          function areaOpen() {
            return !(
              resource.data.keys().hasAny(['completedAt']) &&
              resource.data.completedAt is timestamp
            );
          }
          function areaIsFresh() {
            return !(
              resource.data.keys().hasAny(['startedAt']) &&
              resource.data.startedAt is timestamp
            );
          }
          function isCycleReset() {
            return request.resource.data.keys().hasAny(['cycleResetAt']);
          }

          allow create: if hasVenueRole(venueId, ['manager','owner'])
            && request.resource.data.keys().hasAny(['name', 'createdAt', 'updatedAt']);

          allow update: if isVenueMember(venueId) && isCycleReset() && (
              request.resource.data.diff(resource.data).changedKeys().hasOnly(['startedAt','completedAt','cycleResetAt']) ||
              request.resource.data.diff(resource.data).changedKeys().hasOnly(['startedAt','completedAt','cycleResetAt','updatedAt'])
            );
          allow update: if hasVenueRole(venueId, ['manager','owner']) && (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['completedAt']) ||
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['startedAt','completedAt']) ||
            (
              isCycleReset() && (
                request.resource.data.diff(resource.data).changedKeys().hasOnly(['startedAt','completedAt','cycleResetAt']) ||
                request.resource.data.diff(resource.data).changedKeys().hasOnly(['startedAt','completedAt','cycleResetAt','updatedAt'])
              )
            ) ||
            (
              (areaOpen() || areaIsFresh()) &&
              request.resource.data.diff(resource.data).changedKeys().hasOnly(['name','cycleResetAt','updatedAt']) &&
              request.resource.data.updatedAt is timestamp
            )
          );

          allow update: if hasVenueRole(venueId, ['manager','owner'])
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['cycleResetAt'])
            && (request.resource.data.cycleResetAt is timestamp);

          allow update: if hasVenueRole(venueId, ['manager','owner'])
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['cycleResetAt','updatedAt'])
            && (request.resource.data.cycleResetAt is timestamp)
            && (request.resource.data.updatedAt is timestamp);

          allow update: if isVenueMember(venueId)
            && !(
              resource.data.keys().hasAny(['startedAt']) &&
              resource.data.startedAt is timestamp
            )
            && request.resource.data.startedAt is timestamp
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['startedAt']);

          allow update: if isVenueMember(venueId)
            && (
              resource.data.keys().hasAny(['startedAt']) &&
              resource.data.startedAt is timestamp
            )
            && !(
              resource.data.keys().hasAny(['completedAt']) &&
              resource.data.completedAt is timestamp
            )
            && request.resource.data.completedAt is timestamp
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['completedAt']);

          // Edit window fields written on completion
          allow update: if isVenueMember(venueId)
            && request.resource.data.diff(resource.data).changedKeys()
                 .hasOnly(['completedAt','editWindowClosesAt','editWindowOpen','edits','countSessionSegments','activeCountingMinutes']);

          // Edit log appended within window
          allow update: if isVenueMember(venueId)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['edits']);

          // Manager override fields
          allow update: if hasVenueRole(venueId, ['manager','owner'])
            && request.resource.data.diff(resource.data).changedKeys()
                 .hasOnly(['managerOverride','overrideBy','overrideAt','overrideReason','edits']);

          allow delete: if hasVenueRole(venueId, ['manager','owner']) && areaOpen();

          match /items/{itemId} {
            allow read: if isVenueMember(venueId);

            function isCountUpdate() {
              return request.resource.data.diff(resource.data).changedKeys()
                .hasOnly(['lastCount','lastCountAt','lastCountBy','lastCountByName','updatedAt'])
                || request.resource.data.keys().hasAny(['lastCount','lastCountAt']);
            }
            function isVarianceUpdate() {
              return request.resource.data.diff(resource.data).changedKeys().hasOnly([
                'varianceAccepted','varianceAcceptedBy','varianceAcceptedAt',
                'varianceFlagged','varianceFlaggedBy','varianceFlaggedAt'
              ]);
            }
            function areaEditWindowOpen() {
              let areaData = get(/databases/$(database)/documents/venues/$(venueId)/departments/$(departmentId)/areas/$(areaId)).data;
              return areaData.editWindowOpen == true ||
                (areaData.keys().hasAny(['editWindowClosesAt']) &&
                 areaData.editWindowClosesAt is timestamp &&
                 areaData.editWindowClosesAt > request.time);
            }
            function isLinkUpdate() {
              let keys = request.resource.data.diff(resource.data).changedKeys();
              return keys.hasOnly([
                'productLinkId','productId','productRef','productName',
                'supplierId','supplierName','packSize','price','cost','updatedAt'
              ]);
            }
            function isNameOnlyCreate() {
              return (
                (request.resource.data.keys().hasOnly(['name']) && request.resource.data.name is string) ||
                (request.resource.data.keys().hasOnly(['name','createdAt','updatedAt']) &&
                  request.resource.data.name is string &&
                  request.resource.data.createdAt is timestamp &&
                  request.resource.data.updatedAt is timestamp)
              );
            }
            function isMetaCreateFull() {
              return (
                (
                  request.resource.data.keys().hasOnly([
                    'name','unit','supplierId','costPrice','salePrice','parLevel',
                    'lastCount','lastCountAt','openingStock','openingSetAt','createdAt','updatedAt'
                  ]) &&
                  request.resource.data.name is string &&
                  (!('createdAt' in request.resource.data) || request.resource.data.createdAt is timestamp) &&
                  request.resource.data.updatedAt is timestamp
                ) ||
                (
                  request.resource.data.keys().hasOnly([
                    'name','unit','supplierId','costPrice','salePrice','parLevel',
                    'lastCount','lastCountAt','openingStock','openingSetAt'
                  ]) &&
                  request.resource.data.name is string
                )
              )
              && (!('openingStock' in request.resource.data) || request.resource.data.openingStock == null || request.resource.data.openingStock is number)
              && (!('openingSetAt' in request.resource.data) || request.resource.data.openingSetAt == null || request.resource.data.openingSetAt is timestamp);
            }
            function isMetaUpdate() {
              return request.resource.data.diff(resource.data).changedKeys().hasOnly([
                'name','unit','supplierId','costPrice','salePrice','parLevel','flagRecount','updatedAt'
              ]) && request.resource.data.updatedAt is timestamp;
            }
            function isInductedCreate() {
              return hasOnlyFields(request.resource.data, [
                'name','unit','supplierName','supplierId',
                'productId','productName',
                'category','brand','size',
                'inductionStatus','inductionSource',
                'countingUnit','caseSize',
                'costPrice','parLevel',
                'lastCount','lastCountAt',
                'lastCountBy','lastCountByName',
                'barcode','barcodeNumber',
                'createdAt','updatedAt'
              ])
              && request.resource.data.name is string
              && request.resource.data.createdAt is timestamp
              && request.resource.data.updatedAt is timestamp
              && request.resource.data.inductionStatus in ['pending','complete']
              && request.resource.data.inductionSource in ['quick-add','smart-shelf-scan','shelf-scan','product-photo','venue-search','venue-search-batch','bulk-assign','barcode-scan']
              && (!('supplierName' in request.resource.data) || request.resource.data.supplierName == null || request.resource.data.supplierName is string)
              && (!('supplierId' in request.resource.data) || request.resource.data.supplierId == null || request.resource.data.supplierId is string)
              && (!('unit' in request.resource.data) || request.resource.data.unit == null || request.resource.data.unit is string)
              && (!('productId' in request.resource.data) || request.resource.data.productId == null || request.resource.data.productId is string)
              && (!('productName' in request.resource.data) || request.resource.data.productName == null || request.resource.data.productName is string)
              && (!('category' in request.resource.data) || request.resource.data.category == null || request.resource.data.category is string)
              && (!('brand' in request.resource.data) || request.resource.data.brand == null || request.resource.data.brand is string)
              && (!('size' in request.resource.data) || request.resource.data.size == null || request.resource.data.size is string)
              && (!('countingUnit' in request.resource.data) || request.resource.data.countingUnit == null || request.resource.data.countingUnit is string)
              && (!('caseSize' in request.resource.data) || request.resource.data.caseSize == null || request.resource.data.caseSize is number)
              && (!('costPrice' in request.resource.data) || request.resource.data.costPrice == null || request.resource.data.costPrice is number)
              && (!('parLevel' in request.resource.data) || request.resource.data.parLevel == null || request.resource.data.parLevel is number)
              && (!('barcode' in request.resource.data) || request.resource.data.barcode == null || request.resource.data.barcode is string)
              && (!('barcodeNumber' in request.resource.data) || request.resource.data.barcodeNumber == null || request.resource.data.barcodeNumber is string);
            }
            function isInductionUpdate() {
              return request.resource.data.diff(resource.data).changedKeys().hasOnly([
                'supplierName','productId','productName','inductionStatus','inductionSource','updatedAt'
              ])
              && request.resource.data.updatedAt is timestamp
              && (!('supplierName' in request.resource.data) || request.resource.data.supplierName == null || request.resource.data.supplierName is string)
              && (!('productId' in request.resource.data) || request.resource.data.productId == null || request.resource.data.productId is string)
              && (!('productName' in request.resource.data) || request.resource.data.productName == null || request.resource.data.productName is string)
              && (!('inductionStatus' in request.resource.data) || request.resource.data.inductionStatus in ['pending','complete'])
              && (!('inductionSource' in request.resource.data) || request.resource.data.inductionSource in ['quick-add','smart-shelf-scan']);
            }
            function isOrderReceiveUpdate() {
              return request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['lastCount','lastCountAt','lastCountBy','lastCountByName','updatedAt'])
                && request.resource.data.lastCount is number;
            }

            allow create: if hasVenueRole(venueId, ['manager','owner'])
              && (
                (
                  hasOnlyFields(request.resource.data, [
                    'name','unit','supplierName','supplierId',
                    'productId','productName',
                    'category','brand','size',
                    'inductionStatus','inductionSource',
                    'countingUnit','caseSize',
                    'lastCount','lastCountAt',
                    'lastCountBy','lastCountByName',
                    'barcode','barcodeNumber',
                    'createdAt','updatedAt'
                  ])
                  && request.resource.data.name is string
                  && request.resource.data.createdAt is timestamp
                  && request.resource.data.updatedAt is timestamp
                ) ||
                (
                  hasOnlyFields(request.resource.data, ['name'])
                  && request.resource.data.name is string
                )
              );

            // resource is null for a brand-new document on create — areaOpen()/areaIsFresh()
            // dereference resource.data, which throws and denies this whole rule for every
            // role (confirmed: manager/owner creates only ever succeeded via the separate
            // hasVenueRole-gated rule above, which never calls these functions; isVenueMember
            // staff creates had no fallback and were always rejected). A new item can always
            // be created into a valid area regardless of prior state — there's no prior
            // document to check completedAt against — so resource == null short-circuits safely.
            allow create: if isVenueMember(venueId)
              && (resource == null || areaOpen() || areaIsFresh())
              && (isNameOnlyCreate() || isMetaCreateFull() || isInductedCreate());

            allow update: if isVenueMember(venueId) && areaOpen()
              && (isCountUpdate() || isLinkUpdate() || isMetaUpdate() || isInductionUpdate());

            // Allow count edits within the 60-minute edit window
            allow update: if isVenueMember(venueId) && isCountUpdate() && areaEditWindowOpen();

            // Allow manager override edits after window closes
            allow update: if hasVenueRole(venueId, ['manager','owner']) && isCountUpdate()
              && get(/databases/$(database)/documents/venues/$(venueId)/departments/$(departmentId)/areas/$(areaId)).data.managerOverride == true;

            // Variance acceptance/flagging by any member before submission completes
            allow update: if isVenueMember(venueId) && isVarianceUpdate();

            // Allow stock count increments from order receive — area may already be closed
            allow update: if isVenueMember(venueId) && isOrderReceiveUpdate();

            allow delete: if isVenueMember(venueId) && areaOpen();
          }
        }

        match /cycles/{cycleId} {
          allow read: if isVenueMember(venueId);
          allow create: if isVenueMember(venueId);
          allow update: if hasVenueRole(venueId, ['manager', 'owner']);
          allow delete: if hasVenueRole(venueId, ['owner']);
        }

        match /reports/{docId} {
          allow read, write: if isVenueMember(venueId);
          match /{sub=**} {
            allow read, write: if isVenueMember(venueId);
          }
        }

        match /snapshots/{snapshotId} {
          allow read: if isVenueMember(venueId);
          allow write: if isVenueMember(venueId);
        }
      }

      match /latestSnapshot {
        allow read: if isVenueMember(venueId);
        allow write: if isVenueMember(venueId);
      }

      // ------- Areas + Items (venue-level legacy) -------
      match /areas/{areaId} {
        allow read: if isVenueMember(venueId);

        allow update: if isVenueMember(venueId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['currentLock'])
          && (
            request.resource.data.currentLock is map ||
            request.resource.data.currentLock == null
          );

        function areaOpen() {
          return !(
            resource.data.keys().hasAny(['completedAt']) &&
            resource.data.completedAt is timestamp
          );
        }
        function areaIsFresh() {
          return !(
            resource.data.keys().hasAny(['startedAt']) &&
            resource.data.startedAt is timestamp
          );
        }
        function isCycleReset() { return request.resource.data.keys().hasAny(['cycleResetAt']); }

        allow create: if hasVenueRole(venueId, ['manager','owner'])
          && request.resource.data.keys().hasAny(['name', 'createdAt', 'updatedAt']);

        allow update: if hasVenueRole(venueId, ['manager','owner']) && (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['completedAt']) ||
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['startedAt','completedAt']) ||
          (
            isCycleReset() && (
              request.resource.data.diff(resource.data).changedKeys().hasOnly(['startedAt','completedAt','cycleResetAt']) ||
              request.resource.data.diff(resource.data).changedKeys().hasOnly(['startedAt','completedAt','cycleResetAt','updatedAt'])
            )
          ) ||
          (
            (areaOpen() || areaIsFresh()) &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['name','cycleResetAt','updatedAt']) &&
            request.resource.data.updatedAt is timestamp
          )
        );

        allow update: if hasVenueRole(venueId, ['manager','owner'])
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['cycleResetAt'])
          && (request.resource.data.cycleResetAt is timestamp);

        allow update: if hasVenueRole(venueId, ['manager','owner'])
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['cycleResetAt','updatedAt'])
          && (request.resource.data.cycleResetAt is timestamp)
          && (request.resource.data.updatedAt is timestamp);

        allow delete: if hasVenueRole(venueId, ['manager','owner']) && areaOpen();

        match /items/{itemId} {
          allow read: if isVenueMember(venueId);

          function isCountUpdate() {
            return request.resource.data.diff(resource.data).changedKeys().hasOnly(['lastCount','lastCountAt'])
              || request.resource.data.keys().hasAny(['lastCount','lastCountAt']);
          }
          function isLinkUpdate() {
            let keys = request.resource.data.diff(resource.data).changedKeys();
            return keys.hasOnly([
              'productLinkId','productId','productRef','productName',
              'supplierId','supplierName','packSize','price','cost','updatedAt'
            ]);
          }
          function isNameOnlyCreate() {
            return (
              (request.resource.data.keys().hasOnly(['name']) && request.resource.data.name is string) ||
              (request.resource.data.keys().hasOnly(['name','createdAt','updatedAt']) &&
                request.resource.data.name is string &&
                request.resource.data.createdAt is timestamp &&
                request.resource.data.updatedAt is timestamp)
            );
          }
          function isMetaCreateFull() {
            return (
              (
                request.resource.data.keys().hasOnly([
                  'name','unit','supplierId','costPrice','salePrice','parLevel',
                  'lastCount','lastCountAt','createdAt','updatedAt'
                ]) &&
                request.resource.data.name is string
                && request.resource.data.createdAt is timestamp
                && request.resource.data.updatedAt is timestamp
              ) ||
              (
                request.resource.data.keys().hasOnly([
                  'name','unit','supplierId','costPrice','salePrice','parLevel',
                  'lastCount','lastCountAt'
                ]) &&
                request.resource.data.name is string
              )
            );
          }
          function isMetaUpdate() {
            return request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'name','unit','supplierId','costPrice','salePrice','parLevel','flagRecount','updatedAt'
            ]) && request.resource.data.updatedAt is timestamp;
          }
          function isInductedCreate() {
            return hasOnlyFields(request.resource.data, [
              'name','unit','supplierName','supplierId',
              'productId','productName',
              'category','brand','size',
              'inductionStatus','inductionSource',
              'countingUnit','caseSize',
              'costPrice','parLevel',
              'lastCount','lastCountAt',
              'barcode','barcodeNumber',
              'createdAt','updatedAt'
            ])
            && request.resource.data.name is string
            && request.resource.data.createdAt is timestamp
            && request.resource.data.updatedAt is timestamp
            && request.resource.data.inductionStatus in ['pending','complete']
            && request.resource.data.inductionSource in ['quick-add','smart-shelf-scan','shelf-scan','product-photo','venue-search','venue-search-batch','bulk-assign','barcode-scan']
            && (!('supplierName' in request.resource.data) || request.resource.data.supplierName == null || request.resource.data.supplierName is string)
            && (!('supplierId' in request.resource.data) || request.resource.data.supplierId == null || request.resource.data.supplierId is string)
            && (!('unit' in request.resource.data) || request.resource.data.unit == null || request.resource.data.unit is string)
            && (!('productId' in request.resource.data) || request.resource.data.productId == null || request.resource.data.productId is string)
            && (!('productName' in request.resource.data) || request.resource.data.productName == null || request.resource.data.productName is string)
            && (!('category' in request.resource.data) || request.resource.data.category == null || request.resource.data.category is string)
            && (!('brand' in request.resource.data) || request.resource.data.brand == null || request.resource.data.brand is string)
            && (!('size' in request.resource.data) || request.resource.data.size == null || request.resource.data.size is string)
            && (!('countingUnit' in request.resource.data) || request.resource.data.countingUnit == null || request.resource.data.countingUnit is string)
            && (!('caseSize' in request.resource.data) || request.resource.data.caseSize == null || request.resource.data.caseSize is number)
            && (!('costPrice' in request.resource.data) || request.resource.data.costPrice == null || request.resource.data.costPrice is number)
            && (!('parLevel' in request.resource.data) || request.resource.data.parLevel == null || request.resource.data.parLevel is number)
            && (!('barcode' in request.resource.data) || request.resource.data.barcode == null || request.resource.data.barcode is string)
            && (!('barcodeNumber' in request.resource.data) || request.resource.data.barcodeNumber == null || request.resource.data.barcodeNumber is string);
          }
          function isInductionUpdate() {
            return request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'supplierName','productId','productName','inductionStatus','inductionSource','updatedAt'
            ])
            && request.resource.data.updatedAt is timestamp
            && (!('supplierName' in request.resource.data) || request.resource.data.supplierName == null || request.resource.data.supplierName is string)
            && (!('productId' in request.resource.data) || request.resource.data.productId == null || request.resource.data.productId is string)
            && (!('productName' in request.resource.data) || request.resource.data.productName == null || request.resource.data.productName is string)
            && (!('inductionStatus' in request.resource.data) || request.resource.data.inductionStatus in ['pending','complete'])
            && (!('inductionSource' in request.resource.data) || request.resource.data.inductionSource in ['quick-add','smart-shelf-scan']);
          }

          allow create: if hasVenueRole(venueId, ['manager','owner'])
            && (
              (
                hasOnlyFields(request.resource.data, [
                  'name','unit','supplierName','supplierId',
                  'productId','productName',
                  'category','brand','size',
                  'inductionStatus','inductionSource',
                  'countingUnit','caseSize',
                  'lastCount','lastCountAt',
                  'createdAt','updatedAt'
                ])
                && request.resource.data.name is string
                && request.resource.data.createdAt is timestamp
                && request.resource.data.updatedAt is timestamp
              ) ||
              (
                hasOnlyFields(request.resource.data, ['name'])
                && request.resource.data.name is string
              )
            );

          // resource is null for a brand-new document on create — see the same fix
          // already deployed on the department-nested block for the full reasoning.
          allow create: if isVenueMember(venueId)
            && (resource == null || areaOpen() || areaIsFresh())
            && (isNameOnlyCreate() || isMetaCreateFull() || isInductedCreate());

          allow update: if isVenueMember(venueId) && areaOpen()
            && (isCountUpdate() || isLinkUpdate() || isMetaUpdate() || isInductionUpdate());

          allow delete: if isVenueMember(venueId) && areaOpen();
        }
      }

      match /suppliers/{supplierId} {
        allow read: if isVenueMember(venueId);
        allow create, update, delete: if hasVenueRole(venueId, ['manager','owner']);
        match /{sub=**} {
          allow read, write: if hasVenueRole(venueId, ['manager','owner']);
        }
      }

      match /products/{productId} {
        allow read: if isVenueMember(venueId);
        allow create: if isVenueMember(venueId);
        // Rule A: manager/owner can update all product fields (name, cost, unit, category, etc.)
        allow update: if hasVenueRole(venueId, ['manager','owner'])
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'name', 'sku', 'unit', 'size', 'packSize', 'caseSize', 'abv',
            'costPrice', 'gstPercent', 'parLevel', 'par',
            'supplierId', 'supplierName', 'supplierUpdatedAt',
            'primarySupplierId', 'primarySupplierName', 'supplierCount', 'lowestUnitCost',
            'updatedAt', 'expiryDate', 'category', 'categorySuggested',
            'active', 'barcode', 'barcodeNumber', 'brand', 'description', 'notes',
            'supplierNameSuggested', 'supplierGlobalId'
          ]);
        // Rule B: any venue member can update supplier-link and par fields
        allow update: if isVenueMember(venueId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'par', 'parLevel', 'supplierId', 'supplierName', 'supplierUpdatedAt',
            'primarySupplierId', 'primarySupplierName', 'supplierCount', 'lowestUnitCost',
            'updatedAt', 'expiryDate'
          ]);
        match /suppliers/{supplierLinkId} {
          allow read: if isVenueMember(venueId);
          allow create, update: if isVenueMember(venueId);
          allow delete: if hasVenueRole(venueId, ['manager','owner']);
        }
        match /prices/{supplierId} {
          allow read, write: if hasVenueRole(venueId, ['manager','owner']);
        }
        match /priceHistory/{entryId} {
          allow read: if isVenueMember(venueId);
          allow write: if isVenueMember(venueId);
        }
        match /{sub=**} {
          allow read, write: if hasVenueRole(venueId, ['manager','owner']);
        }
      }

      match /productNotes/{noteId} {
        allow get, list: if isVenueMember(venueId);
        allow create, update: if isVenueMember(venueId);
        allow delete: if hasVenueRole(venueId, ['manager','owner']);
      }

      match /recipes/{recipeId} {
        allow read: if isVenueMember(venueId);
        allow create: if hasVenueRole(venueId, ['manager','owner'])
          && request.resource.data.status == 'draft'
          && request.resource.data.createdAt is timestamp
          && request.resource.data.updatedAt is timestamp;
        allow update: if hasVenueRole(venueId, ['manager','owner'])
          && resource.data.status == 'draft'
          && request.resource.data.updatedAt is timestamp
          && (request.resource.data.status in ['draft','confirmed']);
        allow delete: if isVenueMember(venueId)
          && (resource.data.status == 'draft'
              || hasVenueRole(venueId, ['manager','owner']));
      }

      match /orders/{orderId} {
        allow get, list: if isVenueMember(venueId) || supplierMatchesOrderData(resource.data);
        // Managers/owners: full create and update
        allow create, update: if hasVenueRole(venueId, ['manager','owner']) || supplierAllowedOrderUpdate();
        // Staff: can create draft orders and route to pending-approval only
        allow create: if hasVenueRole(venueId, ['staff'])
          && request.resource.data.status in ['draft', 'pending-approval'];
        allow update: if hasVenueRole(venueId, ['staff'])
          && request.resource.data.status in ['draft', 'pending-approval'];
        allow delete: if hasVenueRole(venueId, ['manager','owner']);
        match /lines/{lineId} {
          allow get, list: if isVenueMember(venueId) ||
            supplierMatchesOrderData(get(/databases/$(database)/documents/venues/$(venueId)/orders/$(orderId)).data);
          allow create, update: if isVenueMember(venueId);
          allow delete: if hasVenueRole(venueId, ['manager','owner']);
        }
        match /{sub=**} {
          allow read, write: if isVenueMember(venueId);
        }
      }

      match /orderLocks/{supplierKey} {
        allow read, write: if isVenueMember(venueId);
      }

      match /invoices/{invoiceId} {
        allow get, list: if isVenueMember(venueId);
        allow create, update: if isVenueMember(venueId);
        allow delete: if hasVenueRole(venueId, ['manager','owner']);
        match /lines/{lineId} {
          allow read, write: if isVenueMember(venueId);
        }
      }

      match /priceExtractionFailures/{failureId} {
        allow read: if isVenueMember(venueId);
        allow write: if false;
      }

      match /budgets/{budgetId} {
        allow read, write: if hasVenueRole(venueId, ['manager','owner']);
        match /{sub=**} {
          allow read, write: if hasVenueRole(venueId, ['manager','owner']);
        }
      }

      match /items/{itemId} {
        allow read: if isVenueMember(venueId);
      }

      match /areas/{areaId}/items/{itemId} {
        allow read: if isVenueMember(venueId);
      }

      match /sessions/{sessionId} {
        allow get, list: if isVenueMember(venueId);
        allow create, update: if isVenueMember(venueId)
          && hasOnlyFields(request.resource.data, [
            'type','status','venueId','departmentId','areaId',
            'itemId','itemName','fromQty','proposedQty',
            'reason','requestedBy','requestedAt','createdAt','updatedAt'
          ])
          && (request.resource.data.status is string)
          && (request.resource.data.createdAt is timestamp);
        allow delete: if false;
        match /wastage/{wastageId} {
          allow read, write: if isVenueMember(venueId);
        }
      }

      match /stockTakes/{stockTakeId} {
        allow read: if isVenueMember(venueId);
        allow create: if isVenueMember(venueId);
        allow update: if hasVenueRole(venueId, ['manager', 'owner']);
        allow delete: if hasVenueRole(venueId, ['owner']);
      }

      match /reports/{docId} {
        allow read, write: if isVenueMember(venueId);
        match /{sub=**} {
          allow read, write: if isVenueMember(venueId);
        }
      }

      match /computed/{docId} {
        allow read, write: if isVenueMember(venueId);
        match /{sub=**} {
          allow read, write: if isVenueMember(venueId);
        }
      }

      match /ocrJobs/{jobId} {
        allow get, list: if isVenueMember(venueId);
        allow create: if isVenueMember(venueId)
          && hasOnlyFields(request.resource.data, ['status','createdAt','updatedAt','uploadedBy','file'])
          && request.resource.data.status == 'uploaded'
          && request.resource.data.createdAt is timestamp
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.uploadedBy == request.auth.uid
          && request.resource.data.file is map
          && request.resource.data.file.path is string;
        allow update: if isVenueMember(venueId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status','updatedAt'])
          && resource.data.status == 'uploaded'
          && request.resource.data.status == 'queued'
          && request.resource.data.updatedAt is timestamp;
        allow delete: if hasVenueRole(venueId, ['owner','manager']);
      }

      match /shelfScanJobs/{scanId} {
        allow get, list: if isVenueMember(venueId);
        allow create: if isVenueMember(venueId)
          && hasOnlyFields(request.resource.data, [
            'status','venueId','departmentId','areaId','areaNameSnapshot',
            'storagePath','createdBy','createdAt','updatedAt'
          ])
          && request.resource.data.status == 'uploaded'
          && request.resource.data.venueId == venueId
          && request.resource.data.createdAt is timestamp
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.storagePath is string
          && (!('departmentId' in request.resource.data) || request.resource.data.departmentId == null || request.resource.data.departmentId is string)
          && (!('areaId' in request.resource.data) || request.resource.data.areaId == null || request.resource.data.areaId is string)
          && (!('areaNameSnapshot' in request.resource.data) || request.resource.data.areaNameSnapshot == null || request.resource.data.areaNameSnapshot is string);
        allow update: if isVenueMember(venueId)
          && resource.data.createdBy == request.auth.uid
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status','updatedAt'])
          && request.resource.data.status in ['queued','processing']
          && request.resource.data.updatedAt is timestamp;
        allow update: if isVenueMember(venueId)
          && resource.data.createdBy == request.auth.uid
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status','appliedAt','appliedBy','updatedAt'])
          && request.resource.data.status == 'applied'
          && request.resource.data.appliedBy == request.auth.uid
          && request.resource.data.appliedAt is timestamp
          && request.resource.data.updatedAt is timestamp;
        allow delete: if hasVenueRole(venueId, ['owner','manager']);
      }

      match /deliveries/{deliveryId} {
        allow get, list: if isVenueMember(venueId);
        allow create: if isVenueMember(venueId)
          && hasOnlyFields(request.resource.data, [
            'status','orderId','supplierId','invoiceNumber','deliveryDate',
            'taxTotals','subTotal','grandTotal',
            'source','attachments','counts','priceVariance',
            'createdAt','updatedAt','receivedAt','receivedBy'
          ])
          && request.resource.data.status == 'draft'
          && request.resource.data.createdAt is timestamp
          && !('receivedAt' in request.resource.data);
        allow update: if isVenueMember(venueId)
          && resource.data.status != 'received'
          && request.resource.data.status in ['draft','receiving','exceptions']
          && request.resource.data.orderId == resource.data.orderId
          && request.resource.data.supplierId == resource.data.supplierId
          && request.resource.data.createdAt == resource.data.createdAt
          && hasOnlyFields(request.resource.data, [
            'status','orderId','supplierId','invoiceNumber','deliveryDate',
            'taxTotals','subTotal','grandTotal',
            'source','attachments','counts','priceVariance',
            'createdAt','updatedAt','receivedAt','receivedBy'
          ])
          && request.resource.data.updatedAt is timestamp
          && (!('counts' in request.resource.data) || (request.resource.data.counts is list));
        allow update: if isVenueMember(venueId)
          && resource.data.status != 'received'
          && request.resource.data.status == 'received'
          && request.resource.data.orderId == resource.data.orderId
          && request.resource.data.supplierId == resource.data.supplierId
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.receivedAt is timestamp;
        allow delete: if false;
      }

      match /pendingDeliveries/{deliveryId} {
        allow get, list: if isVenueMember(venueId);
        allow create: if isVenueMember(venueId);
        allow update: if hasVenueRole(venueId, ['manager','owner','staff']);
        allow delete: if hasVenueRole(venueId, ['manager','owner']);
      }

      match /orderCounters/{dateKey} {
        allow get, list: if isVenueMember(venueId);
        allow create: if hasVenueRole(venueId, ['manager','owner'])
          && hasOnlyFields(request.resource.data, ['seq','dateKey'])
          && request.resource.data.dateKey == dateKey
          && (request.resource.data.seq is int)
          && request.resource.data.seq == 1;
        allow update: if hasVenueRole(venueId, ['manager','owner'])
          && hasOnlyFields(request.resource.data, ['seq','dateKey'])
          && request.resource.data.dateKey == dateKey
          && (request.resource.data.seq is int && resource.data.seq is int)
          && request.resource.data.seq == resource.data.seq + 1;
        allow delete: if false;
      }

      match /counters_orders/{dateKey} {
        allow get, list: if isVenueMember(venueId);
        allow create: if hasVenueRole(venueId, ['manager','owner'])
          && hasOnlyFields(request.resource.data, ['seq','dateKey'])
          && request.resource.data.dateKey == dateKey
          && (request.resource.data.seq is int)
          && request.resource.data.seq == 1;
        allow update: if hasVenueRole(venueId, ['manager','owner'])
          && hasOnlyFields(request.resource.data, ['seq','dateKey'])
          && request.resource.data.dateKey == dateKey
          && (request.resource.data.seq is int && resource.data.seq is int)
          && request.resource.data.seq == resource.data.seq + 1;
        allow delete: if false;
      }

      match /reconciliations/{id} {
        allow get, list: if isVenueMember(venueId);
        allow create: if isVenueMember(venueId)
          && request.resource.data.kind == 'invoice_reconcile'
          && request.resource.data.createdAt is timestamp;
        allow update, delete: if hasVenueRole(venueId, ['manager','owner']);
      }

      match /fastReceives/{fastId} {
        allow get, list: if isVenueMember(venueId);
        allow create: if isVenueMember(venueId)
          && request.resource.data.kind == 'fast_receive_snapshot'
          && request.resource.data.createdAt is timestamp;
        allow update: if isVenueMember(venueId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status'])
          && request.resource.data.status in ['pending','attached','reconciled'];
        allow delete: if hasVenueRole(venueId, ['manager','owner']);
      }

      match /sales/{saleId} {
        allow get, list: if isVenueMember(venueId);
        allow create, update: if hasVenueRole(venueId, ['manager','owner']);
        allow delete: if hasVenueRole(venueId, ['owner']);
      }

      match /salesReports/{reportId} {
        allow get, list: if isVenueMember(venueId);
        allow create: if isVenueMember(venueId)
          && hasOnlyFields(request.resource.data, ['source','report','createdAt'])
          && request.resource.data.source in ['csv','pdf']
          && request.resource.data.createdAt is timestamp;
        allow update: if false;
        allow delete: if hasVenueRole(venueId, ['manager','owner']);
      }

      match /salesReportMatches/{id} {
        allow get, list: if isVenueMember(venueId);
        allow create: if isVenueMember(venueId)
          && hasOnlyFields(request.resource.data, ['reportId','counts','matches','period','createdAt'])
          && request.resource.data.createdAt is timestamp;
        allow update: if false;
        allow delete: if hasVenueRole(venueId, ['manager','owner']);
      }

      match /salesReportUnknowns/{id} {
        allow get, list: if isVenueMember(venueId);
        allow create: if isVenueMember(venueId)
          && hasOnlyFields(request.resource.data, ['reportId','line','createdAt','status'])
          && request.resource.data.status == 'unmapped'
          && request.resource.data.createdAt is timestamp;
        allow update: if hasVenueRole(venueId, ['manager','owner'])
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status'])
          && request.resource.data.status in ['unmapped','mapped'];
        allow delete: if hasVenueRole(venueId, ['manager','owner']);
      }
      match /photoCountCorrections/{docId} {
        allow read: if hasVenueRole(venueId, ['manager','owner']);
        allow create: if isVenueMember(venueId);
      }
      match /aiContext/{docId} {
        allow get: if isVenueMember(venueId);
        allow write: if isVenueMember(venueId);
      }
      match /recipeSalesAttribution/{id} {
        allow get, list: if isVenueMember(venueId);
        allow create: if isVenueMember(venueId)
          && request.resource.data.createdAt is timestamp;
        allow update: if false;
        allow delete: if hasVenueRole(venueId, ['manager','owner']);
      }
      match /reports/theoreticalConsumption {
        allow get: if isVenueMember(venueId);
        allow write: if isVenueMember(venueId);
      }

      match /aiUsage/{monthKey} {
        allow get, list: if isVenueMember(venueId);
        allow create, update: if isVenueMember(venueId);
      }

      match /importJobs/{jobId} {
        allow get, list: if isVenueMember(venueId);
        allow create: if isVenueMember(venueId)
          && request.resource.data.createdAt is timestamp;
        allow update: if isVenueMember(venueId)
          && request.resource.data.diff(resource.data).changedKeys()
               .hasOnly(['status','finishedAt','counts','errors'])
          && request.resource.data.status in [
               'processing','completed','completed_with_errors','queued','failed'
             ];
        allow delete: if hasVenueRole(venueId, ['manager','owner']);
      }

      match /slowMovers/{slowMoverId} {
        allow read: if isVenueMember(venueId);
        allow update: if hasVenueRole(venueId, ['manager','owner']);
        allow delete: if hasVenueRole(venueId, ['manager','owner']);
      }

      match /processedInvoices/{hash} {
        allow read, write: if isVenueMember(venueId);
      }

      match /processedSalesReports/{hash} {
        allow read, write: if isVenueMember(venueId);
      }

      match /processedStocktakes/{hash} {
        allow read, write: if isVenueMember(venueId);
      }

      // ═══════════════════════════════════════════════════════════════
      // FESTIVAL MODE — additive only
      // All existing venue rules unchanged above
      // ═══════════════════════════════════════════════════════════════

      // Festival: managers can update HQ area config (name, type, dimensions, servingBarIds)
      match /departments/hq/areas/{areaId} {
        allow update: if hasVenueRole(venueId, ['manager','owner'])
          && request.resource.data.diff(resource.data).changedKeys()
               .hasOnly(['name','type','dimensions','hasAisle','aisleWidth','servingBarIds','updatedAt']);
        allow update: if isVenueMember(venueId)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['distributionConfirmed','distributionConfirmedAt','updatedAt']);
      }

      match /bars/{barId} {
        allow read, write: if isVenueMember(venueId);
        match /stocktakes/{stocktakeId} {
          allow read, write: if isVenueMember(venueId);
        }
        match /stock/{productId} {
          allow read, write: if isVenueMember(venueId);
        }
      }

      match /sourceLocations/{locationId} {
        allow read, write: if isVenueMember(venueId);
        match /stock/{productId} {
          allow read, write: if isVenueMember(venueId);
        }
      }

      match /transfers/{transferId} {
        allow read, write: if isVenueMember(venueId);
      }

      match /wastage/{wastageId} {
        allow read: if isVenueMember(venueId);
        allow create: if isVenueMember(venueId)
          && request.resource.data.createdAt is timestamp;
        allow update, delete: if false;
      }

      match /requests/{requestId} {
        allow read, write: if isVenueMember(venueId);
        match /messages/{messageId} {
          allow read, write: if isVenueMember(venueId);
        }
      }

      match /contracts/{contractId} {
        // Private — owner only
        allow read, write: if hasVenueRole(venueId, ['owner']);
      }

      match /riders/{riderId} {
        allow read, write: if isVenueMember(venueId);
      }

      match /consumables/{productId} {
        allow read, write: if isVenueMember(venueId);
      }

      match /returns/{returnId} {
        allow read, write: if isVenueMember(venueId);
        match /pallets/{palletId} {
          allow read, write: if isVenueMember(venueId);
        }
      }

      // Wildcard covers barCounts, photos, and any future returns subcollections
      match /returns/{document=**} {
        allow read, write: if isVenueMember(venueId);
      }

      match /activations/{activationId} {
        allow read, write: if isVenueMember(venueId);
      }

      match /obligations/{obligationId} {
        // Obligations visible to managers and owners
        // Contract terms (contracts/) remain owner only
        allow read: if hasVenueRole(venueId, ['owner', 'manager']);
        allow write: if hasVenueRole(venueId, ['owner']);
      }

      match /priceChangeFlags/{flagId} {
        allow read: if isVenueMember(venueId);
        allow update: if hasVenueRole(venueId, ['manager', 'owner']);
        // Flags are created by Cloud Functions only
        allow create: if false;
        allow delete: if false;
      }

      match /notifications/{notificationId} {
        allow read: if isVenueMember(venueId);
        allow update: if hasVenueRole(venueId, ['manager', 'owner'])
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read']);
        // Written by Cloud Functions only (Admin SDK bypasses these rules)
        allow create: if false;
        allow delete: if false;
      }

      match /priceDisputes/{disputeId} {
        allow read: if isVenueMember(venueId);
        allow create: if hasVenueRole(venueId, ['owner', 'manager'])
          && request.resource.data.createdAt is timestamp
          && request.resource.data.status == 'open';
        allow update: if hasVenueRole(venueId, ['owner', 'manager']);
        allow delete: if hasVenueRole(venueId, ['owner']);
      }

      // Festival Phase 4 — intelligence layer
      match /predictions/{predId} {
        allow read, write: if hasVenueRole(venueId, ['owner', 'manager']);
      }

      match /planograms/{planId} {
        allow read, write: if isVenueMember(venueId);
      }

      match /event/{docId} {
        allow read: if isVenueMember(venueId);
        allow write: if hasVenueRole(venueId, ['owner', 'manager']);
        match /historicalData/{yearId} {
          allow read: if isVenueMember(venueId);
          allow write: if hasVenueRole(venueId, ['owner', 'manager']);
        }
        match /shortfalls/{id} {
          allow read, write: if hasVenueRole(venueId, ['owner', 'manager']);
        }
        match /weeklySnapshots/{weekId} {
          allow read: if isVenueMember(venueId);
          allow write: if hasVenueRole(venueId, ['owner', 'manager']);
        }
        match /salesData/{uploadId} {
          allow read: if isVenueMember(venueId);
          allow write: if hasVenueRole(venueId, ['owner', 'manager']);
        }
        match /salesRecords/{recordId} {
          allow read: if isVenueMember(venueId);
          allow write: if hasVenueRole(venueId, ['owner', 'manager']);
        }
        match /posMappings/{mappingId} {
          allow read: if isVenueMember(venueId);
          allow write: if hasVenueRole(venueId, ['owner', 'manager']);
        }
      }

      match /eventHistory/{eventId} {
        allow read: if hasVenueRole(venueId, ['owner', 'manager']);
        allow write: if hasVenueRole(venueId, ['owner', 'manager']);
        match /debriefRecommendations/{recId} {
          allow read: if isVenueMember(venueId);
          allow write: if hasVenueRole(venueId, ['owner', 'manager']);
        }
      }
    }

    match /squarePkceVerifiers/{venueId} {
      allow write: if isVenueMember(venueId);
      allow read: if isVenueMember(venueId);
    }

    match /squareMerchants/{merchantId} {
      allow read, write: if false;
    }
  }
}
