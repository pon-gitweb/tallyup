{
  "$schema": "https://unpkg.com/knip@latest/schema.json",

  "entry": [
    "App.tsx",
    "src/App.tsx",
    "src/navigation/RootNavigator.tsx"
  ],

  "project": [
    "./tsconfig.knip.json"
  ],

  "ignore": [
    "backups/**",
    "tests-skipped/**",
    "_archive/**",
    "**/*.backup.*",
    "**/*.broken.*",
    "**/*.stale.*",

    "functions/**",
    "backend/functions/**",
    "server/**",
    "scripts/**",

    "node_modules/**"
  ],

  "ignoreDependencies": [
    "firebase",
    "expo-constants",
    "expo-document-picker",
    "expo-file-system",
    "expo-haptics",
    "expo-image-picker",
    "expo-print",
    "expo-sharing",
    "@react-native-community/netinfo",
    "react-native-get-random-values",
    "@expo/vector-icons",
    "uuid"
  ],

  "ignoreDevDependencies": [
    "@babel/core",
    "@testing-library/react-native",
    "firebase-admin",
    "pdf-parse"
  ]
}
