{
  "$schema": "https://unpkg.com/knip@latest/schema.json",

  "entry": [
    "index.js",
    "App.tsx",
    "src/App.tsx",
    "src/navigation/RootNavigator.tsx",
    "babel.config.js",
    "metro.config.js"
  ],

  "project": [
    "./tsconfig.knip.json"
  ],

  "ignore": [
    "backups/**",
    "tests-skipped/**",
    "_archive/**",
    "**/*.backup.*",
    "**/*.broken.*",
    "**/*.stale.*",

    "functions/**",
    "backend/functions/**",
    "server/**",
    "scripts/**",

    "node_modules/**"
  ]
}
