{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "22.19.0",
      "env": {
        "EXPO_PUBLIC_AI_URL": "https://us-central1-tallyup-f1463.cloudfunctions.net/api"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development"
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "environment": "development"
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_AI_URL": "https://us-central1-tallyup-f1463.cloudfunctions.net/api",
        "SENTRY_AUTH_TOKEN": "$SENTRY_AUTH_TOKEN"
      },
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.2"
      }
    },
    "play-aab": {
      "extends": "base",
      "android": {
        "buildType": "app-bundle"
      },
      "distribution": "store",
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_AI_URL": "https://us-central1-tallyup-f1463.cloudfunctions.net/api",
        "SENTRY_AUTH_TOKEN": "$SENTRY_AUTH_TOKEN"
      }
    },
    "tester-apk": {
      "extends": "base",
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "environment": "development"
    },
    "ios-simulator": {
      "extends": "base",
      "ios": {
        "simulator": true
      },
      "distribution": "internal",
      "environment": "development"
    },
    "ios-preview": {
      "extends": "base",
      "distribution": "internal",
      "environment": "development"
    },
    "ios-store": {
      "extends": "base",
      "ios": {
        "enterpriseProvisioning": "adhoc"
      },
      "distribution": "store",
      "environment": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_AI_URL": "https://us-central1-tallyup-f1463.cloudfunctions.net/api",
        "SENTRY_AUTH_TOKEN": "$SENTRY_AUTH_TOKEN"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
