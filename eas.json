{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "22.19.0"
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development"
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "environment": "development"
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "environment": "production"
    },
    "play-aab": {
      "extends": "base",
      "android": {
        "buildType": "app-bundle"
      },
      "distribution": "store",
      "environment": "production"
    },
    "tester-apk": {
      "extends": "base",
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "environment": "development"
    },
    "ios-simulator": {
      "extends": "base",
      "ios": {
        "simulator": true
      },
      "distribution": "internal",
      "environment": "development"
    },
    "ios-preview": {
      "extends": "base",
      "ios": {
        "buildType": "simulator"
      },
      "distribution": "internal",
      "environment": "development"
    },
    "ios-store": {
      "extends": "base",
      "ios": {
        "buildType": "archive"
      },
      "distribution": "store",
      "environment": "production",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "",
        "ascAppId": "",
        "appleTeamId": ""
      }
    }
  }
}